  },
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "bun run typecheck && bun run lint",
    "build": "bun run check && bun run ./scripts/build.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^14.0.0",
    "figures": "^6.1.0",
    "giget": "^3.3.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "string-width": "^8.2.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "eslint": "^10.4.0",
    "typescript": "^5.8.3"
  }
}
