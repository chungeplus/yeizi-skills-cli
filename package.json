{
  "name": "yeizi-skills",
  "type": "module",
  "version": "0.1.1",
  "packageManager": "bun@1.3.14",
  "description": "CLI for managing yeizi skills.",
  "author": "yeizi",
  "license": "MIT",
  "homepage": "https://github.com/chungeplus/yeizi-skills-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chungeplus/yeizi-skills-cli.git"
  },
  "bugs": {
    "url": "https://github.com/chungeplus/yeizi-skills-cli/issues"
  },
  "keywords": [
    "skill",
    "cli"
  ],
  "bin": {
    "yeizi-skills": "dist/index.js"
  },
  "publishConfig": {
